# Copy to .env.local and fill in values. .env.local is gitignored.

# --- Firebase web app (use your dev project, or any placeholder when using emulators only) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Local Firebase Emulator Suite (ports must match firebase.json) ---
# Set to "true" while emulators are running so the app uses local Firestore, Auth, and Storage.
# npm run dev:emulators sets this automatically for the Next process (no need to flip it here).
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Optional overrides (defaults match firebase.json emulators section)
# NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
# NEXT_PUBLIC_AUTH_EMULATOR_PORT=9099
# NEXT_PUBLIC_STORAGE_EMULATOR_PORT=9199

# After first emulator start, seed Firestore in the Emulator UI (Firestore tab), for example:
#   Collection: counter   Document ID: s5Lwh7q9cNZvYSJDAc2N   Field: report-no (number) e.g. 1000
#
# Or copy Firestore from production into the emulator (service account JSON; emulators running):
#   PowerShell: $env:GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\key.json"
#   All root collections, small sample per collection:
#     npm run seed:firestore -- --all
#   npm run seed:firestore -- --all --limit=15
#   Named collections only: npm run seed:firestore -- projects orders --limit=50

# --- Server: submit mail (PO / SR / PR) ---
# In `next dev`, /api/mail/po|sr|pr does NOT call Applied BAS (no customer email).
# Optional overrides (not needed for normal local dev):
#   SKIP_MAIL_ON_SUBMIT=true   # skip upstream in any NODE_ENV (e.g. `next start` smoke)
#   FORCE_MAIL_SEND=true       # always call upstream (e.g. Playwright E2E against local dev)

# --- Other app env (see your team / prod config) ---
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
# NEXT_PUBLIC_OPENAI_API_KEY=
