# Copy to .env.local and fill in values. .env.local is gitignored.

# --- Firebase web app (use your dev project, or any placeholder when using emulators only) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Local Firebase Emulator Suite (ports must match firebase.json) ---
# Set to "true" while emulators are running so the app uses local Firestore, Auth, and Storage.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Optional overrides (defaults match firebase.json emulators section)
# NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
# NEXT_PUBLIC_AUTH_EMULATOR_PORT=9099
# NEXT_PUBLIC_STORAGE_EMULATOR_PORT=9199

# After first emulator start, seed Firestore in the Emulator UI (Firestore tab), for example:
#   Collection: counter   Document ID: s5Lwh7q9cNZvYSJDAc2N   Field: report-no (number) e.g. 1000

# --- Other app env (see your team / prod config) ---
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
# NEXT_PUBLIC_OPENAI_API_KEY=
